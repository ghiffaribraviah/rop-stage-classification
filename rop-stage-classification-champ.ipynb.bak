   "source": [
    "# Small helpers the viz functions rely on (local-only).\n",
    "def read_rgb_file(path) -> np.ndarray:\n",
    "    image = cv2.imread(str(path), cv2.IMREAD_COLOR)\n",
    "    if image is None:\n",
    "        raise FileNotFoundError(\n",
    "            f\"OpenCV could not decode {path}. If local, check Git LFS files are present.\")\n",
    "    return cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n",
    "\n",
    "\n",
    "def is_readable_image(path) -> bool:\n",
    "    return cv2.imread(str(path), cv2.IMREAD_COLOR) is not None\n",
    "\n",
    "\n",
    "def make_splits(df: pd.DataFrame, protocol: str = \"group\"):\n",
    "    X = np.arange(len(df)); y = df[\"label_id\"].values\n",
    "    if protocol == \"group\":\n",
    "        sp = StratifiedGroupKFold(n_splits=5, shuffle=True, random_state=SEED)\n",
    "        return sp.split(X, y, groups=df[\"group\"].values)\n",
    "    if protocol == \"stratified\":\n",
    "        sp = StratifiedKFold(n_splits=5, shuffle=True, random_state=SEED)\n",
    "        return sp.split(X, y)\n",
    "    raise ValueError(\"protocol must be 'group' or 'stratified'\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "6027156c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── image-sheet rendering helpers ────────────────────────────────────────────\n",
    "def uint8_image(image: np.ndarray) -> np.ndarray:\n",
    "    if image.dtype == bool:\n",
    "        return image.astype(np.uint8) * 255\n",
    "    if np.issubdtype(image.dtype, np.floating):\n",
    "        return np.clip(image, 0.0, 1.0) * 255.0\n",
    "    return np.clip(image, 0, 255).astype(np.uint8)\n",
    "\n",
    "\n",
    "def to_rgb_tile(image: np.ndarray) -> np.ndarray:\n",
    "    image = uint8_image(image)\n",
    "    if image.ndim == 2:\n",
    "        return np.repeat(image[:, :, None], 3, axis=2)\n",
    "    return image[:, :, :3]\n",
    "\n",
    "\n",
    "def add_label(image: np.ndarray, label: str, tile_size: int = 180) -> np.ndarray:\n",
    "    tile = to_rgb_tile(image)\n",
    "    tile = cv2.resize(tile, (tile_size, tile_size), interpolation=cv2.INTER_AREA)\n",
    "    band = np.full((32, tile_size, 3), 255, dtype=np.uint8)\n",
    "    cv2.putText(band, str(label)[:32], (5, 22), cv2.FONT_HERSHEY_SIMPLEX, 0.48, (0, 0, 0), 1, cv2.LINE_AA)\n",
    "    return np.vstack([band, tile])\n",
    "\n",
    "\n",
    "def save_sheet(rows, output_path: Path, tile_size: int = 180) -> Path:\n",
    "    output_path.parent.mkdir(parents=True, exist_ok=True)\n",
    "    rendered_rows = []\n",
    "    for row in rows:\n",
    "        rendered_rows.append(np.concatenate([add_label(image, label, tile_size) for label, image in row], axis=1))\n",
    "    sheet = np.concatenate(rendered_rows, axis=0)\n",
    "    cv2.imwrite(str(output_path), cv2.cvtColor(sheet, cv2.COLOR_RGB2BGR))\n",
    "    return output_path"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cad3756b",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── per-image champion debug maps (plain-Gabor vessel channel) ───────────────\n",
    "# NOTE: cfg.process_max_side -> PROCESS_MAX_SIDE, cfg.image_size -> IMAGE_SIZE.\n",
    "# The vessel channel label is \"Vessel plain-Gabor\" because champ does NOT use the\n",
    "# 0.40/0.60 gabor+meijering fusion that bravi uses.\n",
    "def champion_debug_maps(path) -> dict:\n",
    "    rgb = read_rgb_file(path)\n",
    "    h, w = rgb.shape[:2]\n",
    "    s = min(1.0, PROCESS_MAX_SIDE / max(h, w))\n",
    "    wrk = cv2.resize(rgb, (int(w * s), int(h * s)), cv2.INTER_AREA) if s < 1 else rgb.copy()\n",
    "    fov = est_fov(wrk)\n",
    "    vessel = vessel_softmap(wrk, fov)\n",
    "    ridge = ridge_softmap(wrk, fov)\n",
    "    green = ridge_source_channel(wrk, fov)\n",
    "    stack = np.stack([vessel, ridge, green], axis=-1)\n",
    "    stack_224 = cv2.resize(stack, (IMAGE_SIZE, IMAGE_SIZE), interpolation=cv2.INTER_AREA)\n",
    "    rgb_control = build_channels_rgb(path)\n",
    "    overlay = wrk.copy()\n",
    "    vessel_mask = vessel >= np.percentile(vessel[fov], 92.0) if np.any(fov) else np.zeros(vessel.shape, dtype=bool)\n",
    "    ridge_mask = ridge >= np.percentile(ridge[fov], 92.0) if np.any(fov) else np.zeros(ridge.shape, dtype=bool)\n",
    "    overlay[vessel_mask] = (0, 220, 120)\n",
    "    overlay[ridge_mask] = (255, 80, 40)\n",
    "    overlay = cv2.addWeighted(wrk, 0.62, overlay, 0.38, 0)\n",
    "    return {\n",
    "        \"original\": wrk,\n",
    "        \"fov\": fov,\n",
    "        \"vessel_softmap\": vessel,\n",
    "        \"ridge_softmap\": ridge,\n",
    "        \"masked_clahe_green\": green,\n",
    "        \"softmap_stack\": stack_224,\n",
    "        \"rgb_ablation\": rgb_control,\n",
    "        \"vessel_ridge_overlay\": overlay,\n",
    "    }\n",
    "\n",
    "\n",
    "def sample_rows_per_class(df: pd.DataFrame, per_class: int = 1, seed: int = SEED,\n",
    "                          max_checks_per_class: int = 50) -> pd.DataFrame:\n",
    "    parts = []\n",
    "    for label in CLASSES:\n",
    "        rows = df[df[\"label\"] == label].sample(frac=1.0, random_state=seed).head(max_checks_per_class)\n",
    "        readable = []\n",
    "        for _, row in rows.iterrows():\n",
    "            if is_readable_image(row[\"path\"]):\n",
    "                readable.append(row)\n",
    "            if len(readable) >= per_class:\n",
    "                break\n",
    "        if readable:\n",
    "            parts.append(pd.DataFrame(readable))\n",
    "        else:\n",
    "            print(f\"No readable preview image found for class {label} after checking up to {max_checks_per_class} files.\")\n",
    "    return pd.concat(parts, ignore_index=True) if parts else pd.DataFrame()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1ad5a4c5",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── preprocessing preview + dataset/fold plots ───────────────────────────────\n",
    "def visualize_champion_preprocessing(df: pd.DataFrame, per_class: int = 1, tile_size: int = 170) -> Path:\n",
    "    sample_df = sample_rows_per_class(df, per_class=per_class, seed=SEED)\n",
    "    if sample_df.empty:\n",
    "        print(\"No readable images available for preprocessing visualization \"\n",
    "              \"(expected if local files are Git LFS pointers).\")\n",
    "        return OUTPUT_FIGURES_DIR / \"champion_preprocessing_sheet.jpg\"\n",
    "    rows = []\n",
    "    for _, row in sample_df.iterrows():\n",
    "        maps = champion_debug_maps(row[\"path\"])\n",
    "        rows.append([\n",
    "            (f\"{row['label']} original\", maps[\"original\"]),\n",
    "            (\"FOV\", maps[\"fov\"]),\n",
    "            (\"Vessel plain-Gabor\", maps[\"vessel_softmap\"]),\n",
    "            (\"Ridge softmap\", maps[\"ridge_softmap\"]),\n",
    "            (\"CLAHE green\", maps[\"masked_clahe_green\"]),\n",
    "            (\"Stack RGB\", maps[\"softmap_stack\"]),\n",
    "            (\"RGB ablation\", maps[\"rgb_ablation\"]),\n",
    "            (\"Overlay\", maps[\"vessel_ridge_overlay\"]),\n",
    "        ])\n",
    "    output_path = OUTPUT_FIGURES_DIR / \"champion_preprocessing_sheet.jpg\"\n",
    "    path = save_sheet(rows, output_path, tile_size=tile_size)\n",
    "    print(f\"Saved preprocessing sheet: {path}\")\n",
    "    try:\n",
    "        from IPython.display import Image, display\n",
    "        display(Image(filename=str(path)))\n",
    "    except Exception:\n",
    "        pass\n",
    "    return path\n",
    "\n",
    "\n",
    "def plot_dataset_summary(df: pd.DataFrame) -> None:\n",
    "    fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "    counts = df[\"label\"].value_counts().reindex(CLASSES)\n",
    "    sns.barplot(x=counts.index, y=counts.values, ax=axes[0])\n",
    "    axes[0].set_title(\"Images per class\"); axes[0].set_xlabel(\"Class\"); axes[0].set_ylabel(\"Count\")\n",
    "    group_counts = df.groupby(\"label\")[\"group\"].nunique().reindex(CLASSES)\n",
    "    sns.barplot(x=group_counts.index, y=group_counts.values, ax=axes[1])\n",
    "    axes[1].set_title(\"Groups per class\"); axes[1].set_xlabel(\"Class\"); axes[1].set_ylabel(\"Groups\")\n",
    "    plt.tight_layout()\n",
    "    path = OUTPUT_FIGURES_DIR / \"dataset_summary.png\"\n",
    "    plt.savefig(path, dpi=150); plt.show()\n",
    "    print(f\"Saved dataset summary: {path}\")\n",
    "\n",
    "\n",
    "def plot_cv_fold_distribution(df: pd.DataFrame, protocol: str = \"group\") -> None:\n",
    "    fold_rows = []\n",
    "    for fold, (_, te) in enumerate(make_splits(df, protocol)):\n",
    "        for label, count in df.iloc[te][\"label\"].value_counts().items():\n",
    "            fold_rows.append({\"fold\": fold, \"label\": label, \"count\": int(count)})\n",
    "    fold_df = pd.DataFrame(fold_rows)\n",
    "    plt.figure(figsize=(10, 4))\n",
    "    sns.barplot(data=fold_df, x=\"fold\", y=\"count\", hue=\"label\", hue_order=CLASSES)\n",
    "    plt.title(f\"{protocol} CV evaluation fold distribution\"); plt.tight_layout()\n",
    "    path = OUTPUT_FIGURES_DIR / f\"{protocol}_fold_distribution.png\"\n",
    "    plt.savefig(path, dpi=150); plt.show()\n",
    "    print(f\"Saved fold distribution: {path}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "49ec7d09",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── OOF result plots ──────────────────────────────────────────────────────────\n",
    "# These need per-image OOF predictions. champ's Modal run_full() prints a summary\n",
    "# but does not emit a per-image OOF CSV, so these are provided for when you have an\n",
    "# oof_df with columns: label, label_id, pred_id, pred_label, path. (Defined now;\n",
    "# call them once you produce such a frame.)\n",
    "def plot_oof_confusion(oof_df: pd.DataFrame, title: str = \"OOF confusion\") -> None:\n",
    "    valid = oof_df[oof_df[\"pred_id\"] >= 0]\n",
    "    cm = confusion_matrix(valid[\"label_id\"], valid[\"pred_id\"], labels=list(range(len(CLASSES))))\n",
    "    plt.figure(figsize=(7, 6))\n",
    "    sns.heatmap(cm, annot=True, fmt=\"d\", cmap=\"Blues\", xticklabels=CLASSES, yticklabels=CLASSES)\n",
    "    plt.xlabel(\"Predicted\"); plt.ylabel(\"True\"); plt.title(title); plt.tight_layout()\n",
    "    path = OUTPUT_FIGURES_DIR / \"oof_confusion_matrix.png\"\n",
    "    plt.savefig(path, dpi=150); plt.show()\n",
    "    print(f\"Saved OOF confusion matrix: {path}\")\n",
    "\n",
    "\n",
    "def plot_oof_error_examples(oof_df: pd.DataFrame, n: int = 12, tile_size: int = 150):\n",
    "    errors = oof_df[(oof_df[\"pred_id\"] >= 0) & (oof_df[\"label\"] != oof_df[\"pred_label\"])].head(n)\n",
    "    if errors.empty:\n",
    "        print(\"No OOF errors to visualize.\")\n",
    "        return None\n",
    "    row_tiles = []; current = []\n",
    "    for _, row in errors.iterrows():\n",
    "        maps = champion_debug_maps(row[\"path\"])\n",
    "        current.append((f\"T:{row['label']} P:{row['pred_label']}\", maps[\"softmap_stack\"]))\n",
    "        if len(current) == 4:\n",
    "            row_tiles.append(current); current = []\n",
    "    if current:\n",
    "        blank = np.zeros((IMAGE_SIZE, IMAGE_SIZE, 3), dtype=np.uint8)\n",
    "        while len(current) < 4:\n",
    "            current.append((\"\", blank))\n",
    "        row_tiles.append(current)\n",
    "    path = OUTPUT_FIGURES_DIR / \"oof_error_examples.jpg\"\n",
    "    save_sheet(row_tiles, path, tile_size=tile_size)\n",
    "    print(f\"Saved OOF error examples: {path}\")\n",
    "    try:\n",
    "        from IPython.display import Image, display\n",
    "        display(Image(filename=str(path)))\n",
    "    except Exception:\n",
    "        pass\n",
    "    return path"
   ]
  },
