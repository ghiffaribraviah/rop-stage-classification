   "source": [
    "# Local-only viz imports and output paths. Independent of the Modal app above.\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.metrics import confusion_matrix\n",
    "\n",
    "# champ uses literal preprocessing constants (no cfg object):\n",
    "IMAGE_SIZE = 224          # final CNN input side (matches build_channels)\n",
    "PROCESS_MAX_SIDE = 768    # long-side working resolution (matches build_channels)\n",
    "SEED = 42                 # matches train_one_fold / CV splits\n",
    "\n",
    "PROJECT_ROOT = Path(\".\").resolve()\n",
    "ZHAO_ROOT = PROJECT_ROOT / \"data\" / \"Zhao2024\"\n",
    "# clean_manifest.json moved during a repo reorg; check both known locations.\n",
    "_MANIFEST_CANDIDATES = [\n",
    "    PROJECT_ROOT / \"experiments\" / \"cnn\" / \"clean_manifest.json\",\n",
    "    PROJECT_ROOT / \"docs\" / \"experiments\" / \"cnn\" / \"clean_manifest.json\",\n",
    "    PROJECT_ROOT / \"clean_manifest.json\",\n",
    "]\n",
    "CLEAN_MANIFEST_PATH = next((p for p in _MANIFEST_CANDIDATES if p.exists()), _MANIFEST_CANDIDATES[0])\n",
    "OUTPUT_FIGURES_DIR = PROJECT_ROOT / \"figures\"\n",
    "OUTPUT_FIGURES_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "sns.set_theme(style=\"whitegrid\")\n",
    "print(\"Viz setup:\")\n",
    "print(\"  ZHAO_ROOT          =\", ZHAO_ROOT, \"(exists:\", ZHAO_ROOT.exists(), \")\")\n",
    "print(\"  CLEAN_MANIFEST_PATH=\", CLEAN_MANIFEST_PATH, \"(exists:\", CLEAN_MANIFEST_PATH.exists(), \")\")\n",
    "print(\"  OUTPUT_FIGURES_DIR =\", OUTPUT_FIGURES_DIR)"
   ]
