  {
   "cell_type": "code",
   "execution_count": null,
   "id": "2ecfe65f",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Local dataframe for visualization. Adds stem/filename/group columns that the\n",
    "# viz helpers need. The Modal run_full() builds its OWN manifest in-container and\n",
    "# is unaffected by anything here.\n",
    "def load_manifest_local(root: Path) -> pd.DataFrame:\n",
    "    exts = {\".jpg\", \".jpeg\", \".png\"}\n",
    "    cls2id = {n: i for i, n in enumerate(CLASSES)}\n",
    "    rows = []\n",
    "    for d, c in DIR2CLASS.items():\n",
    "        dd = root / d\n",
    "        if not dd.exists():\n",
    "            print(f\"Warning: missing class directory: {dd}\")\n",
    "            continue\n",
    "        for p in sorted(dd.iterdir()):\n",
    "            if p.suffix.lower() in exts and p.is_file():\n",
    "                rows.append({\"path\": str(p), \"filename\": p.name, \"stem\": p.stem,\n",
    "                             \"label\": c, \"label_id\": cls2id[c], \"key\": f\"{c}_{p.stem}\"})\n",
    "    out = pd.DataFrame(rows)\n",
    "    if out.empty:\n",
    "        raise ValueError(f\"No images found under {root}\")\n",
    "    return out\n",
    "\n",
    "\n",
    "def assign_groups_local(df: pd.DataFrame, manifest_path: Path) -> np.ndarray:\n",
    "    gid = {}\n",
    "    if manifest_path.exists():\n",
    "        for rec in json.load(open(manifest_path)):\n",
    "            name = rec.get(\"name\") or rec.get(\"filename\") or rec.get(\"path\")\n",
    "            grp = rec.get(\"group\")\n",
    "            if name is not None and grp is not None:\n",
    "                gid[Path(str(name)).stem] = int(grp)\n",
    "        print(f\"Loaded {len(gid)} grouped stems from {manifest_path}\")\n",
    "    else:\n",
    "        print(\"clean_manifest.json not found; using singleton groups (group protocol).\")\n",
    "    base = (max(gid.values()) + 1) if gid else 0\n",
    "    groups = np.empty(len(df), dtype=int)\n",
    "    for i, stem in enumerate(df[\"stem\"].values):\n",
    "        groups[i] = gid.get(stem, base + i)\n",
    "    return groups\n",
    "\n",
    "\n",
    "df = load_manifest_local(ZHAO_ROOT)\n",
    "df[\"group\"] = assign_groups_local(df, CLEAN_MANIFEST_PATH)\n",
    "print(f\"Loaded {len(df)} images\")\n",
    "display(df[\"label\"].value_counts().reindex(CLASSES))\n",
    "display(df.head())"
   ]
  },
  {
   "cell_type": "code",
