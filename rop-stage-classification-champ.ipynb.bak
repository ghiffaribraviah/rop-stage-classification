    "## Run Controls (local visualizations)\n",
    "\n",
    "Toggle the flags below and run this cell to render the local visualizations\n",
    "inline. These are LOCAL plots only. The actual training / 5-fold CV still runs on\n",
    "Modal via the `@app.function` + `@app.local_entrypoint()` defined earlier — launch\n",
    "it from the repo root with, e.g.:\n",
    "\n",
    "```bash\n",
    "modal run rop-stage-classification-champ.ipynb --mode full --protocol group\n",
    "```\n",
    "\n",
    "(`--mode quick_channel` or `--mode quick_fov` for short smoke tests.)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fe7ac2ba",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Local visualization controls. Set flags, then run this cell.\n",
    "RUN_DATASET_SUMMARY = True\n",
    "RUN_FOLD_DISTRIBUTION = True\n",
    "RUN_PREVIEW = True\n",
    "\n",
    "VIZ_PROTOCOL = \"group\"        # 'group' (leakage-aware) or 'stratified' (lineage comparison)\n",
    "\n",
    "if RUN_DATASET_SUMMARY:\n",
    "    plot_dataset_summary(df)\n",
    "\n",
    "if RUN_FOLD_DISTRIBUTION:\n",
    "    plot_cv_fold_distribution(df, protocol=VIZ_PROTOCOL)\n",
    "\n",
    "if RUN_PREVIEW:\n",
    "    visualize_champion_preprocessing(df, per_class=1)\n",
    "\n",
    "print(\"\\nLocal visualizations done. Training/CV runs on Modal — see the Run \"\n",
    "      \"Controls markdown above for the `modal run` command.\")"
   ]
  }
